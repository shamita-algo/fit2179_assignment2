{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Natural Disasters in Australia Over Time",
    "subtitle": "Number of recorded disaster events per year",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "width": 700,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/shamita-algo/fit2179_assignment2/refs/heads/main/disasters_clean.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"filter": "datum.year >= 1950 && datum.year <= 2023"},
    {
      "aggregate": [{"op": "count", "as": "count"}],
      "groupby": ["year"]
    }
  ],
  "layer": [
    {
      "mark": {"type": "line", "color": "#e74c3c", "strokeWidth": 2},
      "encoding": {
        "x": {"field": "year", "type": "quantitative", "axis": {"title": "Year", "format": "d"}},
        "y": {"field": "count", "type": "quantitative", "axis": {"title": "Number of Disasters"}},
        "tooltip": [
          {"field": "year", "title": "Year", "format": "d"},
          {"field": "count", "title": "Disasters"}
        ]
      }
    },
    {
      "mark": {"type": "point", "color": "#e74c3c", "size": 50, "filled": true},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "count", "type": "quantitative"},
        "tooltip": [
          {"field": "year", "title": "Year", "format": "d"},
          {"field": "count", "title": "Disasters"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#d73027", "strokeWidth": 1.5, "strokeDash": [4, 2]},
      "encoding": {
        "x": {"datum": 1998, "type": "quantitative"}
      }
    },
    {
      "mark": {
        "type": "text",
        "color": "#d73027",
        "fontSize": 11,
        "fontWeight": "bold",
        "dx": 5,
        "dy": -80,
        "align": "left"
      },
      "encoding": {
        "x": {"datum": 1998, "type": "quantitative"},
        "y": {"datum": 11, "type": "quantitative"},
        "text": {"value": "1998 — Peak year with 11 disasters"}
      }
    }
  ]
}