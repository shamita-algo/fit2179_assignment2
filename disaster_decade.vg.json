{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Natural Disasters by Type and Decade",
    "subtitle": "Breakdown of disaster categories across decades",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "width": 600,
  "height": 350,
  "data": {
    "url": "https://raw.githubusercontent.com/shamita-algo/fit2179_assignment2/refs/heads/main/disasters_clean.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"filter": "datum.year >= 1950 && datum.year <= 2023"},
    {
      "calculate": "floor(datum.year / 10) * 10 + 's'",
      "as": "decade"
    },
    {
      "aggregate": [{"op": "count", "as": "count"}],
      "groupby": ["decade", "category"]
    }
  ],
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "decade",
          "type": "ordinal",
          "axis": {"title": "Decade", "labelAngle": 0}
        },
        "y": {
          "field": "count",
          "type": "quantitative",
          "axis": {"title": "Number of Disasters"}
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Flood", "Storm", "Cyclone", "Bushfire", "Landslide"],
            "range": ["#4575b4", "#fdae61", "#74add1", "#d73027", "#8c6d3f"]
          },
          "legend": {"title": "Disaster Type"}
        },
        "order": {"field": "category", "type": "nominal"},
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "category", "title": "Type"},
          {"field": "count", "title": "Count"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "color": "#333333",
        "fontSize": 11,
        "fontWeight": "bold",
        "dy": -10,
        "align": "center"
      },
      "encoding": {
        "x": {"datum": "2010s", "type": "ordinal"},
        "y": {"datum": 62, "type": "quantitative"},
        "text": {"value": "Busiest decade — 61 disasters"}
      }
    }
  ]
}