{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Disaster Type Rankings by Decade",
    "subtitle": "How the most common disaster types have changed over time",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "width": 600,
  "height": 300,
  "data": {
    "url": "https://raw.githubusercontent.com/shamita-algo/fit2179_assignment2/refs/heads/main/disasters_clean.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"filter": "datum.year >= 1950 && datum.year <= 2023"},
    {"calculate": "floor(datum.year / 10) * 10 + 's'", "as": "decade"},
    {
      "aggregate": [{"op": "count", "as": "count"}],
      "groupby": ["decade", "category"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "count", "order": "descending"}],
      "groupby": ["decade"]
    }
  ],
  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 3},
      "encoding": {
        "x": {
          "field": "decade",
          "type": "ordinal",
          "axis": {"title": "Decade", "labelAngle": 0}
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "sort": "ascending",
          "axis": {"title": "Rank", "values": [1, 2, 3, 4, 5]}
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Flood", "Storm", "Cyclone", "Bushfire", "Landslide"],
            "range": ["#4575b4", "#fdae61", "#74add1", "#d73027", "#8c6d3f"]
          },
          "legend": {"title": "Disaster Type"}
        },
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "category", "title": "Type"},
          {"field": "rank", "title": "Rank"},
          {"field": "count", "title": "Count"}
        ]
      }
    },
    {
      "mark": {"type": "point", "filled": true, "size": 100},
      "encoding": {
        "x": {
          "field": "decade",
          "type": "ordinal"
        },
        "y": {
          "field": "rank",
          "type": "quantitative",
          "sort": "ascending"
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Flood", "Storm", "Cyclone", "Bushfire", "Landslide"],
            "range": ["#4575b4", "#fdae61", "#74add1", "#d73027", "#8c6d3f"]
          }
        },
        "tooltip": [
          {"field": "decade", "title": "Decade"},
          {"field": "category", "title": "Type"},
          {"field": "rank", "title": "Rank"},
          {"field": "count", "title": "Count"}
        ]
      }
    }
  ]
}