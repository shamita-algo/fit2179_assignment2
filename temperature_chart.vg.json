{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
      "text": "Australia's Rising Temperatures (1910–2023)",
      "subtitle": "Annual mean temperature anomaly relative to 1961–1990 average",
      "fontSize": 16,
      "subtitleFontSize": 12
    },
    "width": 700,
    "height": 300,
    "data": {
      "url": "https://raw.githubusercontent.com/shamita-algo/fit2179_assignment2/refs/heads/main/temperature_clean.csv",
      "format": {"type": "csv"}
    },
    "layer": [
      {
        "mark": {"type": "bar", "opacity": 0.7},
        "encoding": {
          "x": {
            "field": "year",
            "type": "ordinal",
            "axis": {"labelAngle": -45, "title": "Year", "labelOverlap": true, "tickCount": 20}
          },
          "y": {
            "field": "anomaly",
            "type": "quantitative",
            "axis": {"title": "Temperature Anomaly (°C)"},
            "scale": {"domain": [-1.5, 1.5]}
          },
          "color": {
            "condition": {"test": "datum.anomaly > 0", "value": "#d73027"},
            "value": "#4575b4"
          },
          "tooltip": [
            {"field": "year", "title": "Year"},
            {"field": "anomaly", "title": "Anomaly (°C)", "format": ".2f"}
          ]
        }
      },
      {
        "mark": {"type": "line", "color": "black", "strokeWidth": 1.5, "opacity": 0.5},
        "transform": [{"loess": "anomaly", "on": "year", "bandwidth": 0.3}],
        "encoding": {
          "x": {"field": "year", "type": "quantitative"},
          "y": {"field": "anomaly", "type": "quantitative"}
        }
      }
    ]
  }