{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
      "text": "Disaster Frequency by Type and Decade",
      "subtitle": "How each disaster type has changed over time",
      "fontSize": 16,
      "subtitleFontSize": 12
    },
    "width": 500,
    "height": 300,
    "data": {
      "url": "data/disasters_clean.csv",
      "format": {"type": "csv"}
    },
    "transform": [
      {"filter": "datum.year >= 1950 && datum.year <= 2023"},
      {
        "calculate": "floor(datum.year / 10) * 10 + 's'",
        "as": "decade"
      },
      {
        "aggregate": [{"op": "count", "as": "count"}],
        "groupby": ["decade", "category"]
      }
    ],
    "mark": "rect",
    "encoding": {
      "x": {
        "field": "decade",
        "type": "ordinal",
        "axis": {"title": "Decade", "labelAngle": 0}
      },
      "y": {
        "field": "category",
        "type": "ordinal",
        "axis": {"title": "Disaster Type"}
      },
      "color": {
        "field": "count",
        "type": "quantitative",
        "scale": {"scheme": "reds"},
        "legend": {"title": "Count"}
      },
      "tooltip": [
        {"field": "decade", "title": "Decade"},
        {"field": "category", "title": "Type"},
        {"field": "count", "title": "Count"}
      ]
    }
  }