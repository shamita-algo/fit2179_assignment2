{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Cost and Impact of Australian Natural Disasters",
    "subtitle": "Each bubble represents a disaster event — size shows fatalities, colour shows type",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "width": 700,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/shamita-algo/fit2179_assignment2/refs/heads/main/disasters_clean.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {"filter": "datum.insured_cost != ''"},
    {"calculate": "toNumber(datum.insured_cost)", "as": "cost"},
    {"filter": "datum.cost > 0 && datum.year <= 2023"},
    {"calculate": "toNumber(datum.fatalities)", "as": "deaths"},
    {"calculate": "datum.cost / 1000000", "as": "cost_millions"}
  ],
  "layer": [
    {
      "mark": {"type": "point", "filled": true, "opacity": 0.7},
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {"title": "Year", "format": "d"},
          "scale": {"domain": [1970, 2023]}
        },
        "y": {
          "field": "cost_millions",
          "type": "quantitative",
          "axis": {"title": "Insured Cost (AUD Millions)", "format": ".0f"}
        },
        "size": {
          "field": "deaths",
          "type": "quantitative",
          "scale": {"range": [50, 1000]},
          "legend": {"title": "Fatalities"}
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Flood", "Storm", "Cyclone", "Bushfire", "Landslide"],
            "range": ["#4575b4", "#fdae61", "#74add1", "#d73027", "#8c6d3f"]
          },
          "legend": {"title": "Disaster Type"}
        },
        "tooltip": [
          {"field": "event", "title": "Event"},
          {"field": "year", "title": "Year"},
          {"field": "category", "title": "Type"},
          {"field": "cost_millions", "title": "Cost (AUD Millions)", "format": ".0f"},
          {"field": "deaths", "title": "Fatalities"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 10,
        "fontWeight": "bold",
        "color": "#d73027",
        "dy": -12,
        "align": "center"
      },
      "transform": [
        {"filter": "datum.cost_millions > 2000"}
      ],
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "cost_millions", "type": "quantitative"},
        "text": {"field": "event", "type": "nominal"}
      }
    }
  ]
}